{
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",
    "target": "esnext",

    "strict": true,
    "types": ["jest"],
    "esModuleInterop": true,

    "sourceMap": true,
    "skipLibCheck": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "isolatedModules": true,
    "moduleDetection": "force"
  }
}